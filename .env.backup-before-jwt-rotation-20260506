NODE_ENV=production

# ── App runtime ──────────────────────────────────────────────────────────────
APP_RUN_DB_INIT=true
PORT=4000
NEXT_PORT=3000
MIDDLEWARE_URL=http://127.0.0.1:4000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=service_catalogue
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/service_catalogue
DB_HOST=postgres
DB_PORT=5432
DB_NAME=service_catalogue
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false



# ── Seed init ────────────────────────────────────────────────────────────────
INIT_WITH_TEST_SEEDS=false
INIT_WITH_C3_TAXONOMY_XLSX_SEED=false

# ── JWT / CORS ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
INSTALL_SETUP_TOKEN=change-me-before-install
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:4000

# ── SSO ──────────────────────────────────────────────────────────────────────
AUTH_SSO_ENABLED=false
AUTH_SSO_HEADER=x-remote-user
AUTH_SSO_DISPLAY_NAME_HEADER=x-remote-name
AUTH_SSO_EMAIL_HEADER=x-remote-email
AUTH_SSO_GIVEN_NAME_HEADER=x-remote-given-name
AUTH_SSO_SURNAME_HEADER=x-remote-surname
AUTH_SSO_DEPARTMENT_HEADER=x-remote-department

# ── Retention ────────────────────────────────────────────────────────────────
ENABLE_RETENTION_SCHEDULER=true
RETENTION_RUNNER_NAME=inline-app
RETENTION_RUNNER_KIND=app-inline
RETENTION_PURGE_INTERVAL_SECONDS=86400
RETENTION_HEARTBEAT_TTL_SECONDS=180

# ── Logging / cache ──────────────────────────────────────────────────────────
LOG_LEVEL=info
CACHE_DASHBOARD_TTL=300
CACHE_C3_TTL=86400
CACHE_C3_DASHBOARD_TTL=600
CACHE_C3_CAPABILITY_MAP_TTL=600
CACHE_LIST_TYPE_TTL=3600
