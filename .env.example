# Core runtime
NODE_ENV=production
APP_VERSION=1.0.2
SCHEMA_VERSION=2.2.1
APP_RUN_DB_INIT=true
PORT=4000
NEXT_PORT=3000
MIDDLEWARE_URL=http://127.0.0.1:4000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=service_catalogue
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# POSTGRES_PASSWORD_FILE=/run/secrets/db_password

# Leave DATABASE_URL empty when using the discrete DB_* settings below.
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_NAME=service_catalogue
DB_USER=postgres
DB_PASSWORD=change-me
# DB_PASSWORD_FILE=/run/secrets/db_password
DB_SSL=false
# DB_SSL_INSECURE_SKIP_VERIFY=false   # set true only for local/dev self-signed TLS

# Seed flags
INIT_WITH_TEST_SEEDS=false
INIT_WITH_C3_ENTITY_SEEDS=false
INIT_WITH_C3_BASELINE_TAXONOMY_SEED=false
INIT_WITH_C3_TAXONOMY_XLSX_SEED=false
INIT_WITH_C3_CAPABILITY_MAP_SEED=false

JWT_SECRET=change-me-to-a-long-random-secret
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# JWT_EXPIRY_MINUTES=60          # Access token lifetime (default: 60 min)
# REFRESH_TOKEN_EXPIRY_DAYS=7    # Refresh token lifetime (default: 7 days)

# Install wizard protection — required on the /install page before the system
# reaches READY state. Set to any secret string, enter the same value in the
# wizard. Remove after installation is complete.
# Leave unset only for local/isolated deployments where the install page is
# not network-accessible.
INSTALL_SETUP_TOKEN=change-me-before-install

CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:4000

AUTH_SSO_ENABLED=false
# Required when AUTH_SSO_ENABLED=true. Reverse proxy must send the same secret
# in a dedicated header before the backend accepts trusted SSO identity headers.
AUTH_SSO_TRUSTED_PROXY_SHARED_SECRET=
AUTH_SSO_TRUSTED_PROXY_HEADER=x-sso-proxy-secret
AUTH_SSO_HEADER=x-remote-user
AUTH_SSO_DISPLAY_NAME_HEADER=x-remote-name
AUTH_SSO_EMAIL_HEADER=x-remote-email
AUTH_SSO_GIVEN_NAME_HEADER=x-remote-given-name
AUTH_SSO_SURNAME_HEADER=x-remote-surname
AUTH_SSO_DEPARTMENT_HEADER=x-remote-department

ENABLE_RETENTION_SCHEDULER=true
RETENTION_RUNNER_NAME=inline-app
RETENTION_RUNNER_KIND=app-inline
RETENTION_PURGE_INTERVAL_SECONDS=86400
RETENTION_HEARTBEAT_TTL_SECONDS=180

LOG_LEVEL=info
CACHE_DASHBOARD_TTL=300
CACHE_C3_TTL=86400
CACHE_C3_DASHBOARD_TTL=600
CACHE_C3_CAPABILITY_MAP_TTL=600
CACHE_LIST_TYPE_TTL=3600

# DB connection pool tuning (optional, sensible defaults apply)
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECT_TIMEOUT_MS=2000

# API rate limiting (optional)
# RATE_LIMIT_API_MAX=500

# SharePoint integration (not used in default deployment)
# SP_SITE_URL=
# SP_CATALOG_LIST=ServiceCatalog
# SP_FLAVOUR_LIST=ServiceFlavours
# SP_RELATION_LIST=ServiceRelations
